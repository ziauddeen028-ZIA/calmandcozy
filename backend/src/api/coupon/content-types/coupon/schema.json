{
  "kind": "collectionType",
  "collectionName": "coupons",
  "info": {
    "singularName": "coupon",
    "pluralName": "coupons",
    "displayName": "Coupon",
    "description": "Discount coupons for orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "percentage",
        "fixed"
      ],
      "required": true,
      "default": "percentage"
    },
    "value": {
      "type": "decimal",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "expiryDate": {
      "type": "datetime"
    },
    "minOrderAmount": {
      "type": "decimal",
      "default": 0
    },
    "maxDiscountAmount": {
      "type": "decimal"
    }
  }
}
